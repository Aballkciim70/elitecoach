// server.js - EliteCoach Backend
const express = require('express');
const cors = require('cors');
const jwt = require('jsonwebtoken');
const bcrypt = require('bcryptjs');
require('dotenv').config();

const app = express();
app.use(cors());
app.use(express.json());

const JWT_SECRET = process.env.JWT_SECRET || 'secret-key';

// Database Mock
let users = [
  { id: 1, name: 'Alice', email: 'client@example.com', password: bcrypt.hashSync('password', 10), role: 'client', age: 28, height: 170, weight: 65, objective: 'Muscle', experience: 'Intermédiaire' },
  { id: 2, name: 'Coach', email: 'coach@example.com', password: bcrypt.hashSync('password', 10), role: 'coach' }
];
let workoutPlans = [];
let workoutLogs = [];
let messages = [];
let clients = [
  { id: 1, name: 'Alice', email: 'client@example.com', coachId: 2, workouts: 12 },
  { id: 2, name: 'Bob', email: 'bob@example.com', coachId: 2, workouts: 8 },
  { id: 3, name: 'Carol', email: 'carol@example.com', coachId: 2, workouts: 15 }
];

// Auth Middleware
const auth = (req, res, next) => {
  const token = req.headers['authorization']?.split(' ')[1];
  if (!token) return res.status(401).json({ error: 'No token' });
  jwt.verify(token, JWT_SECRET, (err, user) => {
    if (err) return res.status(403).json({ error: 'Invalid token' });
    req.user = user;
    next();
  });
};

// Auth Routes
app.post('/api/auth/login', (req, res) => {
  const { email, password } = req.body;
  const user = users.find(u => u.email === email);
  if (!user || !bcrypt.compareSync(password, user.password)) {
    return res.status(401).json({ error: 'Invalid credentials' });
  }
  const token = jwt.sign({ id: user.id, role: user.role }, JWT_SECRET, { expiresIn: '7d' });
  res.json({ token, user: { id: user.id, name: user.name, email: user.email, role: user.role, age: user.age, height: user.height, weight: user.weight, objective: user.objective, experience: user.experience } });
});

app.post('/api/auth/register', (req, res) => {
  const { name, email, password } = req.body;
  if (users.find(u => u.email === email)) return res.status(400).json({ error: 'User exists' });
  const newUser = { id: Math.max(...users.map(u => u.id), 0) + 1, name, email, password: bcrypt.hashSync(password, 10), role: 'client' };
  users.push(newUser);
  const token = jwt.sign({ id: newUser.id, role: newUser.role }, JWT_SECRET, { expiresIn: '7d' });
  res.json({ token, user: { id: newUser.id, name: newUser.name, email: newUser.email, role: newUser.role } });
});

// Profile Routes
app.get('/api/profile', auth, (req, res) => {
  const user = users.find(u => u.id === req.user.id);
  if (!user) return res.status(404).json({ error: 'User not found' });
  res.json({ id: user.id, name: user.name, email: user.email, role: user.role, age: user.age, height: user.height, weight: user.weight, objective: user.objective, experience: user.experience });
});

app.post('/api/profile', auth, (req, res) => {
  const user = users.find(u => u.id === req.user.id);
  if (!user) return res.status(404).json({ error: 'User not found' });
  Object.assign(user, req.body);
  res.json(user);
});

// Workout Routes
app.post('/api/workout/generate', auth, (req, res) => {
  const user = users.find(u => u.id === req.user.id);
  const plans = {
    'Muscle': { 'Day1': { focus: 'Chest', exercises: [{ name: 'Bench', sets: 4, reps: '8-10' }] } },
    'Fat Loss': { 'Day1': { focus: 'HIIT', exercises: [{ name: 'Burpees', sets: 3, reps: '15' }] } }
  };
  const plan = plans[user?.objective] || plans['Muscle'];
  const newPlan = { id: Math.max(...workoutPlans.map(p => p.id || 0), 0) + 1, userId: user.id, plan, createdAt: new Date() };
  workoutPlans.push(newPlan);
  res.json({ plan: newPlan });
});

app.get('/api/workout/latest', auth, (req, res) => {
  const latest = workoutPlans.filter(p => p.userId === req.user.id).sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt))[0];
  if (!latest) return res.status(404).json({ error: 'No plan' });
  res.json(latest);
});

app.get('/api/workout/history', auth, (req, res) => {
  const history = workoutLogs.filter(w => w.userId === req.user.id);
  res.json(history);
});

app.post('/api/workout/log', auth, (req, res) => {
  const log = { id: Math.max(...workoutLogs.map(l => l.id || 0), 0) + 1, userId: req.user.id, ...req.body, createdAt: new Date() };
  workoutLogs.push(log);
  res.json(log);
});

// Messages Routes
app.post('/api/messages', auth, (req, res) => {
  const msg = { id: Math.max(...messages.map(m => m.id || 0), 0) + 1, userId: req.user.id, ...req.body, createdAt: new Date() };
  messages.push(msg);
  res.json(msg);
});

app.get('/api/conversations/:id', auth, (req, res) => {
  const convMsgs = messages.filter(m => m.conversationId === parseInt(req.params.id));
  res.json({ messages: convMsgs });
});

// Coach Routes
app.get('/api/coach/clients', auth, (req, res) => {
  if (req.user.role !== 'coach') return res.status(403).json({ error: 'Forbidden' });
  const coachClients = clients.filter(c => c.coachId === req.user.id);
  res.json(coachClients);
});

app.get('/api/coach/client/:id', auth, (req, res) => {
  if (req.user.role !== 'coach') return res.status(403).json({ error: 'Forbidden' });
  const client = clients.find(c => c.id === parseInt(req.params.id));
  if (!client) return res.status(404).json({ error: 'Client not found' });
  res.json(client);
});

app.get('/api/coach/client/:id/analytics', auth, (req, res) => {
  if (req.user.role !== 'coach') return res.status(403).json({ error: 'Forbidden' });
  res.json({ totalWorkouts: 35, thisWeek: 5, lastWorkout: new Date() });
});

app.post('/api/coach/client/:id/message', auth, (req, res) => {
  if (req.user.role !== 'coach') return res.status(403).json({ error: 'Forbidden' });
  const msg = { id: Math.max(...messages.map(m => m.id || 0), 0) + 1, coachId: req.user.id, clientId: parseInt(req.params.id), ...req.body, createdAt: new Date() };
  messages.push(msg);
  res.json(msg);
});

app.get('/api/coach/client/:id/messages', auth, (req, res) => {
  if (req.user.role !== 'coach') return res.status(403).json({ error: 'Forbidden' });
  const clientMsgs = messages.filter(m => m.clientId === parseInt(req.params.id));
  res.json(clientMsgs);
});

// Health
app.get('/api/health', (req, res) => res.json({ status: 'ok' }));

// Start
const PORT = process.env.PORT || 5000;
app.listen(PORT, () => console.log(`\n🚀 Server on port ${PORT}\n`));